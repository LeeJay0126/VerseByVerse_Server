PORT=4000
HOST=0.0.0.0

NODE_ENV=production
TRUST_PROXY=1

MONGO_URI=your_mongodb_connection_string
SESSION_SECRET=replace_with_a_long_random_secret

CLIENT_ORIGIN=https://your-web-app-domain.com
CLIENT_ORIGINS=

APP_NAME=VerseByVerse
APP_URL=https://your-web-app-domain.com

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
MAIL_FROM="VerseByVerse <no-reply@your-domain.com>"
